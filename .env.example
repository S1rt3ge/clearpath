# =============================================================================
# ClearPath - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in the values:
#   cp .env.example .env

# -----------------------------------------------------------------------------
# PostgreSQL (used automatically through Docker Compose)
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql+asyncpg://clearpath_user:clearpath_pass@postgres:5432/clearpath

# -----------------------------------------------------------------------------
# Ollama (runs locally on the host machine, outside Docker)
# Make sure Ollama is running: ollama serve
# Pull the model: ollama pull gemma4:e2b-it-q4_K_M
# -----------------------------------------------------------------------------
OLLAMA_BASE_URL=http://host.docker.internal:11434
GEMMA_LOCAL_MODEL=gemma4:e2b-it-q4_K_M

# -----------------------------------------------------------------------------
# Google AI Studio
# Get a key: https://aistudio.google.com/apikey
# -----------------------------------------------------------------------------
GOOGLE_AI_STUDIO_API_KEY=your_key_here
GEMMA_CLOUD_MODEL=gemini-2.0-flash

# -----------------------------------------------------------------------------
# Cache
# -----------------------------------------------------------------------------
CACHE_TTL_MINUTES=5

# -----------------------------------------------------------------------------
# App
# -----------------------------------------------------------------------------
APP_ENV=development
LOG_LEVEL=INFO
